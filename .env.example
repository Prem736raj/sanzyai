# Server-side only. Never expose this in frontend files.
GROQ_API_KEY=replace_with_new_key

# Optional: defaults to llama-3.1-8b-instant
GROQ_MODEL=llama-3.1-8b-instant

# Optional local backend port
PORT=8787

# Optional: comma-separated CORS allowlist (production should include your domain only)
# Example: https://sanzyai.com,https://www.sanzyai.com
CORS_ALLOW_ORIGINS=

# Optional: API rate limiting and payload constraints
RATE_LIMIT_GLOBAL_LIMIT=180
RATE_LIMIT_GLOBAL_WINDOW_MS=60000
RATE_LIMIT_CHAT_LIMIT=45
RATE_LIMIT_CHAT_WINDOW_MS=60000
RATE_LIMIT_NEWS_LIMIT=40
RATE_LIMIT_NEWS_WINDOW_MS=300000
MAX_CHAT_BODY_BYTES=12000
MAX_DEFAULT_BODY_BYTES=25000

# Optional: AI news freshness/cache control
AI_NEWS_CACHE_TTL_MS=180000
